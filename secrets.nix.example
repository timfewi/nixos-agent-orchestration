# ─────────────────────────────────────────────────────────────────────
# secrets.nix.example — Agenix encrypted secrets for Hermes agents
#
# This file is OPTIONAL. It configures encrypted .age files that get
# decrypted at build time and mounted at /run/agenix/<name>.
#
# Quick start:
#   1. Uncomment `agenix` input in flake.nix
#   2. Uncomment `inputs.agenix.nixosModules.age` in the host module list
#   3. Import this file in configuration.nix:
#        imports = [ ./secrets.nix ];
#   4. Replace "hermes-agent-*" with your actual agent names
#   5. Create encrypted .age files:
#        mkdir -p secrets
#        echo "OPENROUTER_API_KEY=sk-or-..." \
#          | agenix -e secrets/hermes-agent-key.env.age --stdin
#   6. Set agenixFile on your mkHermesAgent call instead of envFile:
#        (mkHermesAgent { name = "my-agent"; agenixFile = "/run/agenix/my-agent-env"; })
#   7. Rebuild: sudo nixos-rebuild switch --flake .#<hostname>
#
# Prerequisites:
#   - SSH key in ~/.ssh/id_ed25519 (for editing secrets locally)
#   - Target host key auto-detected on NixOS (for build-time decryption)
#     Add other editors' SSH pubkeys as needed
#   - agenix CLI: nix shell nixpkgs#agenix
# ─────────────────────────────────────────────────────────────────────

{ config, lib, pkgs, ... }:

let
  # ── Agent names — replace with your own ──
  # Must match the `name` argument in your mkHermesAgent calls.
  agentNames = [
    "hermes-agent-alpha"
    "hermes-agent-beta"
  ];

  # ── Recipient SSH public keys — add yours + target hosts ──
  # Get your key:        cat ~/.ssh/id_ed25519.pub
  # Get host key:        ssh-keyscan <hostname>
  # Add each pubkey as a recipient so they can decrypt.
  recipients = [
    "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA..."  # Your dev machine
    "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA..."  # Target NixOS host
  ];

  # Transform agent names into age.secrets entries
  mkSecret = name: {
    "${name}-env" = {
      file = ./secrets/${name}.env.age;
      owner = name;
      group = name;
      mode = "0600";
    };
  };

in
{
  # ── Option A: Auto-generated (requires nixpkgs 23.11+) ──
  # age.secrets = lib.mergeAttrsList (map mkSecret agentNames);

  # ── Option B: Manual (compatible with all nixpkgs versions) ──
  # age.secrets = {
  #   "hermes-agent-alpha-env" = {
  #     file = ./secrets/hermes-agent-alpha.env.age;
  #     owner = "hermes-agent-alpha";
  #     group = "hermes-agent-alpha";
  #     mode = "0600";
  #   };
  #   "hermes-agent-beta-env" = {
  #     file = ./secrets/hermes-agent-beta.env.age;
  #     owner = "hermes-agent-beta";
  #     group = "hermes-agent-beta";
  #     mode = "0600";
  #   };
  # };
}
