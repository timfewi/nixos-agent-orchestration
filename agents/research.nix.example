# ────────────────────────────────────────────────────────────
# research.nix.example — Research agent with web tools
#
# Demonstrates extra volumes and per-agent configuration.
# Agents are fully isolated — separate state, user, API key.
# ────────────────────────────────────────────────────────────

{ mkHermesAgent }:
[
  # ── Research agent ──
  (mkHermesAgent {
    name = "research";
    # envFile = "/run/secrets/hermes-research.env";

    extraEnvironment = {
      HERMES_PROFILE = "research";
      HERMES_WEB_BACKEND = "firecrawl";
    };

    # Mount a shared data volume (read-only for safety)
    # extraVolumes = [
    #   "/mnt/data/research:/data:ro"
    # ];
  })

  # ── API agent ──
  # (mkHermesAgent {
  #   name = "api-bot";
  #   envFile = "/run/secrets/hermes-api.env";
  #   extraEnvironment = {
  #     HERMES_PROFILE = "api";
  #   };
  # })
]
