# ────────────────────────────────────────────────────────────
# coding.nix.example — Example coding-agent definition
#
# Copy to my-agents.nix and customize for your own agents.
#
# Usage:
#   cp agents/coding.nix.example my-agents.nix
#   # Edit env file path, API key, extra config
#   sudo nixos-rebuild switch --flake .#agent-host
# ────────────────────────────────────────────────────────────

{ mkHermesAgent }:
[
  # ── Coding agent ──
  (mkHermesAgent {
    name = "coding";
    # envFile = "/run/secrets/hermes-coding.env";
    # stateDir = "/var/lib/hermes-coding";

    extraEnvironment = {
      HERMES_PROFILE = "coding";
      HERMES_DISPLAY_TOOL_PROGRESS = "off";
    };

    # extraVolumes = [
    #   "/home/admin/projects:/home/admin/projects:ro"
    # ];
  })

  # ── Personal agent ──
  # (mkHermesAgent {
  #   name = "personal";
  #   envFile = "/run/secrets/hermes-personal.env";
  #   extraEnvironment = {
  #     HERMES_PROFILE = "personal";
  #   };
  # })

  # ── Research agent ──
  # (mkHermesAgent {
  #   name = "research";
  #   envFile = "/run/secrets/hermes-research.env";
  #   extraEnvironment = {
  #     HERMES_PROFILE = "research";
  #   };
  # })
]
