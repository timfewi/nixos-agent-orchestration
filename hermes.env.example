# ────────────────────────────────────────────────────────────
# Hermes agent environment variables
#
# Copy to /run/secrets/hermes-<name>.env and fill in your keys.
#
#   sudo mkdir -p /run/secrets
#   sudo cp hermes.env.example /run/secrets/hermes-coding.env
#   sudo chmod 600 /run/secrets/hermes-coding.env
#   sudo vi /run/secrets/hermes-coding.env
# ────────────────────────────────────────────────────────────

# Required: OpenRouter API key for model access
OPENROUTER_API_KEY=sk-or-...

# Optional: Telegram bot token for gateway messaging
# TELEGRAM_BOT_TOKEN=...

# Optional: Other provider keys
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...
# GROQ_API_KEY=...
# FIRECRAWL_API_KEY=...
